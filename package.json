{
  "name": "hexo-cloudflare-counter",
  "version": "0.1.0",
  "description": "兼容 LeanCloud Counter API 的 Hexo 阅读量统计后端服务，支持 Cloudflare Workers、Docker 和 Node.js 自托管，内置 D1/SQLite 存储方案。",
  "author": "CaoMeiYouRen",
  "private": true,
  "license": "MIT",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "release": "pnpm run release:service",
    "release:service": "semantic-release",
    "changeset": "changeset",
    "version:packages": "changeset version",
    "release:packages": "changeset publish",
    "lint": "cross-env NODE_ENV=production eslint . --fix",
    "prebuild": "rimraf dist",
    "build": "cross-env NODE_ENV=production tsdown",
    "dev": "cross-env NODE_ENV=development tsx watch apps/server/src/index.ts",
    "dev:tsdown": "cross-env NODE_ENV=development tsdown --watch",
    "start": "node ./dist/index.mjs",
    "start:tsx": "cross-env NODE_ENV=production tsx apps/server/src/index.ts",
    "start:benchmarks": "cross-env NODE_ENV=test BENCHMARKS_TEST=true node dist/index.mjs",
    "start:benchmarks:bun": "cross-env NODE_ENV=test BENCHMARKS_TEST=true bun dist/bun.mjs",
    "commit": "cz",
    "prepare": "husky",
    "test": "vitest run",
    "migrate:leancloud": "tsx scripts/migrate-leancloud-counter.ts",
    "test:benchmarks": "tsx scripts/benchmarks.ts",
    "test:benchmarks:bun": "bun scripts/benchmarks.ts",
    "dev:vercel": "vercel dev",
    "deploy:vercel": "vercel",
    "dev:wrangler": "wrangler dev --env dev",
    "deploy:wrangler": "wrangler deploy",
    "dev:bun": "cross-env NODE_ENV=development bun --watch apps/server/src/bun.ts",
    "typecheck": "tsc --noEmit",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@types/autocannon": "^7.12.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.10",
    "@types/debug": "^4.1.12",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.0",
    "@vercel/nft": "^1.5.0",
    "autocannon": "^8.0.0",
    "commitizen": "^4.3.1",
    "commitlint": "^20.4.4",
    "commitlint-config-cmyr": "^1.0.0",
    "conventional-changelog-cmyr-config": "^3.0.0",
    "cross-env": "^10.0.0",
    "cz-conventional-changelog-cmyr": "^2.0.0",
    "debug": "^4.4.3",
    "eslint": "^9.34.0",
    "eslint-config-cmyr": "^2.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "octokit": "^5.0.5",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "tsdown": "^0.21.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vercel": "^50.32.5",
    "vite": "^8.0.5",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  },
  "config": {},
  "changelog": {
    "language": "zh"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "npm run lint",
      "git add"
    ]
  },
  "keywords": [
    "cloudflare-workers",
    "d1",
    "hexo",
    "vercel",
    "leancloud",
    "docker",
    "typescript",
    "hono"
  ],
  "homepage": "https://github.com/CaoMeiYouRen/hexo-cloudflare-counter#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CaoMeiYouRen/hexo-cloudflare-counter.git"
  },
  "bugs": {
    "url": "https://github.com/CaoMeiYouRen/hexo-cloudflare-counter/issues"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.13",
    "await-to-js": "^3.0.0",
    "better-bytes": "^1.2.6",
    "better-sqlite3": "^12.8.0",
    "cmyr-sign": "^1.1.2",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.3.4",
    "hono": "^4.12.14",
    "isomorphic-unfetch": "^4.0.2",
    "lodash-es": "^4.18.1",
    "tslib": "^2.8.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "pnpm": {
    "overrides": {
      "compare-func": "^2.0.0",
      "js-yaml": "4.1.1",
      "handlebars": "4.7.9",
      "@manypkg/get-packages": "2.2.2",
      "tar": "7.5.11",
      "basic-ftp": "5.2.2",
      "form-data": "^4.0.4",
      "defu": "6.1.5",
      "flatted": "3.4.2",
      "@conventional-changelog/git-client": "^2.5.1",
      "glob": "^11.1.0",
      "lodash": "4.18.0",
      "minimatch@9.0.6": "9.0.7",
      "minimatch@10.1.1": "10.2.5",
      "minimatch@10.2.2": "10.2.5",
      "rollup": "4.59.0",
      "undici": "6.24.0",
      "esbuild": "^0.25.12",
      "path-to-regexp": "^6.3.0",
      "tmp": "^0.2.4"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "workerd"
    ]
  },
  "type": "module"
}