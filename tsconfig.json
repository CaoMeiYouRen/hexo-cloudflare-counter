{
    "compilerOptions": {
        "baseUrl": ".",
        "module": "esnext",
        "target": "esnext",
        "noImplicitAny": false,
        "allowJs": true,
        "checkJs": true,
        "sourceMap": false,
        "rootDir": "./",
        "outDir": "./dist",
        "declaration": true,
        "importHelpers": true,
        "strictPropertyInitialization": false,
        "allowSyntheticDefaultImports": true,
        "experimentalDecorators": true,
        "removeComments": false,
        "resolveJsonModule": true,
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "paths": {
            "@hexo-cloudflare-counter/core": [
                "./packages/core/src/index.ts"
            ],
            "@hexo-cloudflare-counter/core/*": [
                "./packages/core/src/*"
            ]
        },
        "lib": [
            "esnext",
            "dom",
            "dom.iterable",
            "scripthost"
        ],
        "skipLibCheck": true,
        "jsx": "react-jsx",
        "jsxImportSource": "hono/jsx"
    },
    "include": [
        "apps/**/*.ts",
        "apps/**/*.tsx",
        "packages/**/*.ts",
        "packages/**/*.tsx",
        "scripts/*.ts",
        "test/*.ts",
        "*.config.ts",
    ],
    "exclude": [
        "node_modules",
        "**/*.spec.ts",
        "**/node_modules/*"
    ]
}